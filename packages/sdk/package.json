{
  "name": "@inbix/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for Inbix — Open Source Cloudflare-native Email API Platform",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "inbix",
    "email",
    "disposable-email",
    "temp-mail",
    "cloudflare",
    "api",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://inbix.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/andriansandi/inbix.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/andriansandi/inbix/issues"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.0"
  }
}
