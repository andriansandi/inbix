{
  "name": "inbix",
  "version": "0.1.0",
  "private": true,
  "description": "Open Source Disposable Email Platform powered by Cloudflare Workers",
  "license": "MIT",
  "homepage": "https://inbix.xyz",
  "repository": {
    "type": "git",
    "url": "https://github.com/andriansandi/inbix.git"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @inbix/database drizzle-kit generate",
    "db:migrate": "pnpm --filter @inbix/database tsx src/migrate.ts",
    "db:studio": "pnpm --filter @inbix/database drizzle-kit studio",
    "deploy": "pnpm --filter @inbix/dashboard build && wrangler deploy",
    "deploy:dashboard": "pnpm --filter @inbix/dashboard build",
    "deploy:worker": "wrangler deploy",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.105.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  }
}
